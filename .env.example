# Core
CORE_HOST=0.0.0.0
CORE_PORT=8080
CORE_ENVIRONMENT=development

# Auth
LOGTO_ISSUER=https://logto.dev
LOGTO_AUDIENCE=https://api.mannaiah.com
# Set a local bypass token and scope to test protected endpoints in development mode.
DEV_AUTH_TOKEN=
DEV_AUTH_SCOPE=contacts:manage orders:manage products:read products:update marketing:manage
AUTH_JWKS_RATE_LIMIT_PER_MINUTE=5
AUTH_JWKS_CACHE_TTL_MS=300000
AUTH_JWKS_HTTP_TIMEOUT_MS=5000

# Logger
LOG_FORMAT=pretty
LOG_LEVEL=info

# Telemetry
TELEMETRY_ENABLED=true
TELEMETRY_SERVICE_NAME=mannaiah-api
TELEMETRY_SERVICE_VERSION=v2.9.0
TELEMETRY_TRACES_ENABLED=true
TELEMETRY_TRACES_EXPORTER=otlp
TELEMETRY_OTLP_ENDPOINT=otel-collector:4317
TELEMETRY_OTLP_INSECURE=false
TELEMETRY_TRACES_SAMPLER=parentbased_traceidratio
TELEMETRY_TRACES_SAMPLER_RATIO=0.10
TELEMETRY_METRICS_ENABLED=true
TELEMETRY_METRICS_PATH=/metrics
TELEMETRY_DB_STATS_INTERVAL_MS=15000

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT_MS=5000
REDIS_READ_TIMEOUT_MS=3000
REDIS_WRITE_TIMEOUT_MS=3000
REDIS_SCAN_COUNT=200
REDIS_BATCH_SIZE=200

# Storage (S3-compatible)
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET_NAME=mannaiah-assets
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_REQUEST_TIMEOUT_MS=5000
STORAGE_CIRCUIT_BREAKER_ENABLED=true
STORAGE_CIRCUIT_BREAKER_MAX_REQUESTS=1
STORAGE_CIRCUIT_BREAKER_INTERVAL_MS=60000
STORAGE_CIRCUIT_BREAKER_TIMEOUT_MS=30000
STORAGE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
REDIS_CIRCUIT_BREAKER_ENABLED=true
REDIS_CIRCUIT_BREAKER_MAX_REQUESTS=1
REDIS_CIRCUIT_BREAKER_INTERVAL_MS=60000
REDIS_CIRCUIT_BREAKER_TIMEOUT_MS=30000
REDIS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Assets JPG Worker
ASSETS_JPG_WORKER_ENABLED=false
ASSETS_JPG_WORKER_CRON=0 * * * *
ASSETS_JPG_WORKER_TAGS=marketplaces
ASSETS_JPG_WORKER_BATCH_SIZE=100
ASSETS_JPG_WORKER_JPEG_QUALITY=90
ASSETS_JPG_WORKER_TIMEOUT_MS=300000

# Database
DB_DRIVER=sqlite
DB_DSN=file::memory:?cache=shared
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MS=600000
DB_CONN_MAX_IDLE_TIME_MS=300000
DB_GORM_LOG_LEVEL=warn
DB_GORM_SLOW_QUERY_THRESHOLD_MS=200

# HTTP
HTTP_APP_NAME=mannaiah-http
HTTP_PREFORK=false
HTTP_SERVER_HEADER=mannaiah
HTTP_READ_TIMEOUT_MS=30000
HTTP_WRITE_TIMEOUT_MS=30000
HTTP_IDLE_TIMEOUT_MS=120000

# Messaging
MESSAGING_GOCHANNEL_BUFFER=100
MESSAGING_RETRY_MAX_RETRIES=3
MESSAGING_RETRY_INITIAL_INTERVAL_MS=100
MESSAGING_RETRY_MAX_INTERVAL_MS=2000
MESSAGING_RETRY_MULTIPLIER=2.0
MESSAGING_DLQ_SUFFIX=.dlq

# Cron
CRON_LOCATION=UTC
CRON_WITH_SECONDS=false

# Falabella
FALABELLA_URL=https://sellercenter-api.falabella.com
FALABELLA_USER_ID=
FALABELLA_API_KEY=
FALABELLA_USER_AGENT=
FALABELLA_API_VERSION=1.0
FALABELLA_REQUEST_TIMEOUT_MS=5000
FALABELLA_VALIDATION_TIMEOUT_MS=3000
FALABELLA_CIRCUIT_BREAKER_ENABLED=true
FALABELLA_CIRCUIT_BREAKER_MAX_REQUESTS=1
FALABELLA_CIRCUIT_BREAKER_INTERVAL_MS=60000
FALABELLA_CIRCUIT_BREAKER_TIMEOUT_MS=30000
FALABELLA_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
FALABELLA_PRODUCT_REALM=falabella
FALABELLA_PRODUCT_CATEGORY_ID=1638
FALABELLA_PRODUCT_GLOBAL_IDENTIFIER=G08010305
FALABELLA_PRODUCT_ATTRIBUTE_SET_ID=5
FALABELLA_PRODUCT_OPERATOR_CODE=FACO
FALABELLA_PRODUCT_FEED_RESOLUTION_ATTEMPTS=6
FALABELLA_PRODUCT_FEED_RESOLUTION_BACKOFF_MS=1000
FALABELLA_PRODUCT_FEED_RESOLUTION_REQUEST_TIMEOUT_MS=5000
FALABELLA_PRODUCT_IMAGE_BASE_URL=
FALABELLA_PRODUCT_IMAGE_TRANSCODE_ENABLED=false
FALABELLA_PRODUCT_IMAGE_TRANSCODE_PUBLIC_BASE_URL=
FALABELLA_PRODUCT_IMAGE_TRANSCODE_ALLOWED_PREFIXES=
FALABELLA_PRODUCT_IMAGE_TRANSCODE_TIMEOUT_MS=15000
FALABELLA_SYNC_STATUS_CRON=*/1 * * * *
FALABELLA_SYNC_STATUS_BATCH_SIZE=50

# WooCommerce
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
WOOCOMMERCE_SYNC_CONTACTS=false
WOOCOMMERCE_SYNC_CONTACTS_CRON=0 0 * * *
WOOCOMMERCE_SYNC_ORDERS=false
WOOCOMMERCE_SYNC_ORDERS_CRON=0 0 * * *
WOOCOMMERCE_SYNC_PAGE_SIZE=100
WOOCOMMERCE_SYNC_WORKERS=8
WOOCOMMERCE_SYNC_TIMEOUT_MS=600000
WOOCOMMERCE_REQUEST_TIMEOUT_MS=5000
WOOCOMMERCE_VERIFY_SSL=true
WOOCOMMERCE_VALIDATION_TIMEOUT_MS=3000
WOOCOMMERCE_CIRCUIT_BREAKER_ENABLED=true
WOOCOMMERCE_CIRCUIT_BREAKER_MAX_REQUESTS=1
WOOCOMMERCE_CIRCUIT_BREAKER_INTERVAL_MS=60000
WOOCOMMERCE_CIRCUIT_BREAKER_TIMEOUT_MS=30000
WOOCOMMERCE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# Sync Record
SYNC_RECORD_ENABLED=true
SYNC_RECORD_RETENTION_DAYS=90
SYNC_RECORD_CLEANUP_ENABLED=true
SYNC_RECORD_CLEANUP_CRON=0 3 * * *
SYNC_RECORD_CLEANUP_TIMEOUT_MS=60000

# Membership
MEMBERSHIP_ENABLED=true

# Analytics (ClickHouse)
ANALYTICS_ENABLED=false
ANALYTICS_CLICKHOUSE_DSN=clickhouse://user:pass@localhost:9000/mannaiah
ANALYTICS_CLICKHOUSE_MAX_OPEN_CONNS=10
ANALYTICS_CLICKHOUSE_MAX_IDLE_CONNS=5
ANALYTICS_CLICKHOUSE_CONN_MAX_LIFETIME_MS=600000
ANALYTICS_CLICKHOUSE_BATCH_SIZE=1000
ANALYTICS_CLICKHOUSE_FLUSH_INTERVAL_MS=5000
ANALYTICS_CLICKHOUSE_MIGRATION_ENABLED=true

# Segment (requires ANALYTICS_ENABLED=true)
SEGMENT_ENABLED=false

# Email Delivery - OPTIONAL
EMAIL_ENABLED=false
EMAIL_PROVIDER=ses
EMAIL_SES_REGION=us-east-1
EMAIL_SES_ACCESS_KEY_ID=
EMAIL_SES_SECRET_ACCESS_KEY=
EMAIL_SES_FROM_ADDRESS=noreply@mannaiah.com
EMAIL_SES_CONFIGURATION_SET=mannaiah-tracking
EMAIL_SES_MAX_SEND_RATE=14
# Set to public API base URL to enable open-tracking pixel injection (e.g. https://api.example.com).
# When empty, pixel injection is disabled.
EMAIL_TRACKING_BASE_URL=

# Campaign
CAMPAIGN_ENABLED=true
CAMPAIGN_SEND_WORKERS=8
CAMPAIGN_SEND_BATCH_SIZE=100
CAMPAIGN_SEND_RATE_LIMIT_PER_SECOND=8
